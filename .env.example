# ============ 数据库 ============
POSTGRES_DB=lkml_patent
POSTGRES_USER=lkml
POSTGRES_PASSWORD=lkml_secret_change_me

# ============ 前端 ============
# VITE_API_BASE 默认空（同源，由 nginx 反代 /api/ 到后端）。
# 仅在前后端分离部署（前端独立域名/端口）时才需指定，例如：
#   VITE_API_BASE=https://api.example.com
# 单机部署（docker-compose 默认）务必留空，否则跨主机访问会失败。
VITE_API_BASE=

# ============ Kernel 镜像 ============
KERNEL_REPO=https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git
KERNEL_FETCH_INTERVAL=86400
# 首次 clone 最大重试次数（大仓库易因 SSL/网络中断失败）
CLONE_MAX_RETRIES=3
# 每次重试间隔（秒）
CLONE_RETRY_INTERVAL=60
# 是否使用浅克隆（depth=1）加速首次拉取：1=启用，0=完整克隆
# 注意：浅克隆丢失历史，无法用于历史 patch 追溯
CLONE_SHALLOW=0

# ============ JWT ============
JWT_SECRET=change_me_to_random_long_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ 首次启动管理员 ============
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin_change_me
INIT_ADMIN_EMAIL=admin@example.com

# ============ LKML 同步 ============
# 注意：lore.kernel.org 已启用 Anubis 反爬，旧的 HTTP mbox 接口失效。
# 后端通过 git 分片镜像读取邮件，无需 HTTP 下载。
# 旧的 LKML_BASE_URL 仅保留以兼容，实际不再使用。
LKML_BASE_URL=https://lore.kernel.org/linux-kernel
# git 分片镜像根 URL（每个分片是一个 ~1GB bare git 仓库）
LKML_GIT_BASE=https://lore.kernel.org/lkml
# 本地 git 分片镜像目录（运行 scripts/download-lkml-mbox.sh 下载后挂载到容器）
# 容器内路径默认 /data/lkml-mirror，与 docker-compose.yml 挂载一致
LKML_MIRROR_PATH=/data/lkml-mirror
LKML_SYNC_CRON=0 3 * * *
DAILY_DIGEST_CRON=0 6 * * *

# ============ OpenCode ============
OPENCODE_API_BASE=https://api.openai.com/v1
OPENCODE_API_KEY=
OPENCODE_MODEL=gpt-4o
OPENCODE_TIMEOUT=600
OPENCODE_MAX_TOKENS=8192
