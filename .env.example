# ============ 数据库 ============
POSTGRES_DB=lkml_patent
POSTGRES_USER=lkml
POSTGRES_PASSWORD=lkml_secret_change_me

# ============ 前端 ============
VITE_API_BASE=http://localhost:8000

# ============ Kernel 镜像 ============
KERNEL_REPO=https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git
KERNEL_FETCH_INTERVAL=86400

# ============ JWT ============
JWT_SECRET=change_me_to_random_long_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ 首次启动管理员 ============
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin_change_me
INIT_ADMIN_EMAIL=admin@example.com

# ============ LKML 同步 ============
LKML_BASE_URL=https://lore.kernel.org/linux-kernel
LKML_SYNC_CRON=0 3 * * *
DAILY_DIGEST_CRON=0 6 * * *

# ============ OpenCode ============
OPENCODE_API_BASE=https://api.openai.com/v1
OPENCODE_API_KEY=
OPENCODE_MODEL=gpt-4o
OPENCODE_TIMEOUT=600
OPENCODE_MAX_TOKENS=8192
