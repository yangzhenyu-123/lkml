# 依赖目录，容器内重新安装以保证纯净
node_modules

# 构建产物，由容器内构建生成
dist
dist-ssr

# 版本控制元数据
.git
.gitignore

# 编辑器与 IDE 配置
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 系统文件
.DS_Store

# 日志文件
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 本地环境变量与临时文件
*.local

# Docker 自身相关文件，避免被打入构建上下文
Dockerfile
.dockerignore
docker-compose*.yml

# 文档与测试快照等非构建必需内容
README.md
*.md
coverage
.nyc_output
